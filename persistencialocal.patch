+package com.undef.superahorro.caparrozruiz.core
+
+import android.content.Context
+import androidx.datastore.core.DataStore
+import androidx.datastore.preferences.core.Preferences
+import androidx.datastore.preferences.preferencesDataStore
+import com.undef.superahorro.caparrozruiz.data.local.AppDatabase
+import com.undef.superahorro.caparrozruiz.data.repository.RoomWalletRepository
+import com.undef.superahorro.caparrozruiz.data.repository.WalletRepository
+
+private val Context.dataStore: DataStore<Preferences> by preferencesDataStore(name = "superahorro_prefs")
+
+object AppContainer {
+    private lateinit var _walletRepository: WalletRepository
+    val walletRepository: WalletRepository get() = _walletRepository
+
+    fun init(context: Context) {
+        val db = AppDatabase.getInstance(context)
+        _walletRepository = RoomWalletRepository(
+            purchaseDao = db.purchaseDao(),
+            productDao = db.productDao(),
+            dataStore = context.dataStore
+        )
+    }
+}
