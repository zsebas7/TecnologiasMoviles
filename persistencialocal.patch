+package com.undef.superahorro.caparrozruiz.data.repository
+
+import androidx.datastore.core.DataStore
+import androidx.datastore.preferences.core.Preferences
+import androidx.datastore.preferences.core.booleanPreferencesKey
+import androidx.datastore.preferences.core.edit
+import androidx.datastore.preferences.core.floatPreferencesKey
+import androidx.datastore.preferences.core.stringPreferencesKey
+import com.undef.superahorro.caparrozruiz.data.local.dao.ProductDao
+import com.undef.superahorro.caparrozruiz.data.local.dao.PurchaseDao
+import com.undef.superahorro.caparrozruiz.data.local.entity.ProductEntity
+import com.undef.superahorro.caparrozruiz.data.local.entity.PurchaseEntity
+import com.undef.superahorro.caparrozruiz.data.local.entity.toEntity
+import com.undef.superahorro.caparrozruiz.data.model.Product
+import com.undef.superahorro.caparrozruiz.data.model.Purchase
+import com.undef.superahorro.caparrozruiz.data.model.User
+import kotlinx.coroutines.flow.Flow
+import kotlinx.coroutines.flow.MutableStateFlow
+import kotlinx.coroutines.flow.StateFlow
+import kotlinx.coroutines.flow.asStateFlow
+import kotlinx.coroutines.flow.map
+
+class RoomWalletRepository(
+    private val purchaseDao: PurchaseDao,
+    private val productDao: ProductDao,
+    private val dataStore: DataStore<Preferences>
+) : WalletRepository {
+
+    private val _draftProducts = MutableStateFlow<List<Product>>(emptyList())
+
+    companion object {
+        val IS_LOGGED_IN = booleanPreferencesKey("is_logged_in")
+        val USER_NAME = stringPreferencesKey("user_name")
+        val USER_EMAIL = stringPreferencesKey("user_email")
+        val USER_CITY = stringPreferencesKey("user_city")
+        val USER_BUDGET = floatPreferencesKey("user_monthly_budget")
+        val NOTIFICATIONS_ENABLED = booleanPreferencesKey("notifications_enabled")
+        val MONTHLY_SUMMARY_ENABLED = booleanPreferencesKey("monthly_summary_enabled")
+    }
+
+    override fun observePurchases(): Flow<List<Purchase>> =
+        purchaseDao.observeAll().map { list -> list.map { it.toDomain() } }
+
+    override fun observeProductsByPurchaseId(): Flow<Map<Long, List<Product>>> =
+        productDao.observeAll().map { list ->
+            list.groupBy { it.purchaseId }.mapValues { (_, products) -> products.map { it.toDomain() } }
+        }
+
+    override fun observeDraftProducts(): Flow<List<Product>> = _draftProducts.asStateFlow()
+
+    override fun observeCurrentUser(): Flow<User> =
+        dataStore.data.map { prefs ->
+            User(
+                name = prefs[USER_NAME] ?: "Usuario",
+                email = prefs[USER_EMAIL] ?: "",
+                city = prefs[USER_CITY] ?: "",
+                monthlyBudget = (prefs[USER_BUDGET] ?: 265000f).toDouble()
+            )
+        }
+
+    override fun observeIsLoggedIn(): Flow<Boolean> =
+        dataStore.data.map { prefs -> prefs[IS_LOGGED_IN] ?: false }
+
+    override fun observeNotificationsEnabled(): Flow<Boolean> =
+        dataStore.data.map { prefs -> prefs[NOTIFICATIONS_ENABLED] ?: true }
+
+    override fun observeMonthlySummaryEnabled(): Flow<Boolean> =
+        dataStore.data.map { prefs -> prefs[MONTHLY_SUMMARY_ENABLED] ?: false }
+
+    override suspend fun addDraftProduct(product: Product) {
+        _draftProducts.value = _draftProducts.value + product
+    }
+
+    override suspend fun removeDraftProduct(productId: Long) {
+        _draftProducts.value = _draftProducts.value.filterNot { it.id == productId }
+    }
+
+    override suspend fun addPurchase(purchase: Purchase, products: List<Product>) {
+        val newId = purchaseDao.insert(purchase.toEntity())
+        if (products.isNotEmpty()) {
+            productDao.insertAll(products.map { it.toEntity(newId) })
+        }
+        _draftProducts.value = emptyList()
+    }
+
+    override suspend fun updatePurchase(purchase: Purchase) {
+        purchaseDao.update(purchase.toEntity())
+    }
+
+    override suspend fun deletePurchase(purchaseId: Long) {
+        purchaseDao.deleteById(purchaseId)
+    }
+
+    override suspend fun updateProduct(purchaseId: Long, product: Product) {
+        productDao.update(product.toEntity(purchaseId))
+    }
+
+    override suspend fun deleteProduct(purchaseId: Long, productId: Long) {
+        productDao.deleteById(productId)
+    }
+
+    override suspend fun saveUser(user: User) {
+        dataStore.edit { prefs ->
+            prefs[USER_NAME] = user.name
+            prefs[USER_EMAIL] = user.email
+            prefs[USER_CITY] = user.city
+            prefs[USER_BUDGET] = user.monthlyBudget.toFloat()
+        }
+    }
+
+    override suspend fun setLoggedIn(logged: Boolean) {
+        dataStore.edit { prefs -> prefs[IS_LOGGED_IN] = logged }
+    }
+
+    override suspend fun setNotificationsEnabled(enabled: Boolean) {
+        dataStore.edit { prefs -> prefs[NOTIFICATIONS_ENABLED] = enabled }
+    }
+
+    override suspend fun setMonthlySummaryEnabled(enabled: Boolean) {
+        dataStore.edit { prefs -> prefs[MONTHLY_SUMMARY_ENABLED] = enabled }
+    }
+
+    override suspend fun ensureSeedData() {
+        if (purchaseDao.count() > 0) return
+        val p1 = purchaseDao.insert(PurchaseEntity(market = "Carrefour", date = "2026-05-01", time = "10:15", total = 38650.0))
+        val p2 = purchaseDao.insert(PurchaseEntity(market = "Disco", date = "2026-04-29", time = "18:40", total = 23400.0))
+        val p3 = purchaseDao.insert(PurchaseEntity(market = "Coto", date = "2026-04-27", time = "12:10", total = 41200.0))
+        purchaseDao.insert(PurchaseEntity(market = "Dia", date = "2026-04-24", time = "20:05", total = 15780.0))
+        productDao.insertAll(listOf(
+            ProductEntity(purchaseId = p1, code = "779123", name = "Arroz largo", description = "Bolsa 1kg", quantity = 2, price = 1800.0),
+            ProductEntity(purchaseId = p1, code = "779456", name = "Aceite", description = "Girasol 900ml", quantity = 1, price = 3200.0),
+            ProductEntity(purchaseId = p2, code = "779111", name = "Leche", description = "Entera 1L", quantity = 4, price = 1100.0),
+            ProductEntity(purchaseId = p3, code = "779333", name = "Fideos", description = "Spaghetti 500g", quantity = 2, price = 1250.0),
+            ProductEntity(purchaseId = p3, code = "779555", name = "Queso", description = "Cremoso 300g", quantity = 1, price = 3600.0)
+        ))
+    }
